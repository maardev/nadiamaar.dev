# ─── Database (Neon Postgres) ──────────────────────────────────────────────────
# Get this from your Neon project dashboard → Connection Details → Connection string
# Add ?sslmode=require at the end for production
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require

# ─── Payload CMS ──────────────────────────────────────────────────────────────
# Long random string used to sign JWTs — keep this secret
PAYLOAD_SECRET=YOUR_PAYLOAD_SECRET_HERE

# ─── Server URL ───────────────────────────────────────────────────────────────
# Production: set to your Vercel domain, e.g. https://your-project.vercel.app
# Vercel also provides VERCEL_PROJECT_PRODUCTION_URL automatically (no https://)
# This variable is used for CORS, image remote patterns, sitemap, and more
NEXT_PUBLIC_SERVER_URL=https://your-project.vercel.app

# ─── Cron jobs ────────────────────────────────────────────────────────────────
# Random secret to authenticate Vercel Cron requests to /api/payload/jobs/run
CRON_SECRET=YOUR_CRON_SECRET_HERE

# ─── Preview mode ─────────────────────────────────────────────────────────────
# Random secret to validate draft preview requests
PREVIEW_SECRET=YOUR_PREVIEW_SECRET_HERE
